{
  "name": "engager",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastify": "^4.28.0",
    "got": "^12.6.1",
    "kysely": "^0.27.3",
    "oauth-1.0a": "^2.2.6",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "nock": "^13.5.4",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
